{
  "name": "@michi-vz/examples",
  "version": "1.0.0",
  "description": "Canonical example configs for michi-vz charts — single source for VitePress, Storybook, and sandbox links",
  "type": "module",
  "private": true,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@michi-vz/core": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beany-vu/michi-vz-mono.git",
    "directory": "packages/examples"
  },
  "homepage": "https://github.com/beany-vu/michi-vz-mono#readme",
  "bugs": "https://github.com/beany-vu/michi-vz-mono/issues"
}
