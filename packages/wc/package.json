{
  "name": "@michi-vz/wc",
  "version": "0.0.0",
  "description": "Native web components (Lit, light DOM) for michi-vz charts",
  "type": "module",
  "files": ["dist"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "require": "./dist/index.cjs" },
    "./gap-chart": { "types": "./dist/gap-chart.d.ts", "import": "./dist/gap-chart.js", "require": "./dist/gap-chart.cjs" },
    "./line-chart": { "types": "./dist/line-chart.d.ts", "import": "./dist/line-chart.js", "require": "./dist/line-chart.cjs" },
    "./area-chart": { "types": "./dist/area-chart.d.ts", "import": "./dist/area-chart.js", "require": "./dist/area-chart.cjs" },
    "./scatter-chart": { "types": "./dist/scatter-chart.d.ts", "import": "./dist/scatter-chart.js", "require": "./dist/scatter-chart.cjs" },
    "./vertical-stack-bar-chart": { "types": "./dist/vertical-stack-bar-chart.d.ts", "import": "./dist/vertical-stack-bar-chart.js", "require": "./dist/vertical-stack-bar-chart.cjs" },
    "./comparable-horizontal-bar-chart": { "types": "./dist/comparable-horizontal-bar-chart.d.ts", "import": "./dist/comparable-horizontal-bar-chart.js", "require": "./dist/comparable-horizontal-bar-chart.cjs" },
    "./dual-horizontal-bar-chart": { "types": "./dist/dual-horizontal-bar-chart.d.ts", "import": "./dist/dual-horizontal-bar-chart.js", "require": "./dist/dual-horizontal-bar-chart.cjs" },
    "./bar-bell-chart": { "types": "./dist/bar-bell-chart.d.ts", "import": "./dist/bar-bell-chart.js", "require": "./dist/bar-bell-chart.cjs" }
  },
  "scripts": { "build": "tsup && tsup --config tsup.bundle.config.ts", "typecheck": "tsc --noEmit" },
  "publishConfig": { "access": "public" },
  "dependencies": {
    "@michi-vz/core": "workspace:*",
    "lit": "^3.2.1"
  }
}
