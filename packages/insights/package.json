{
  "name": "@michi-vz/insights",
  "version": "0.0.1",
  "description": "Opt-in, client-side AI insights (forecast/anomaly/embeddings/narrate/validate/sql/agent) for michi-vz",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@michi-vz/core": "workspace:*"
  },
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beany-vu/michi-vz-mono.git",
    "directory": "packages/insights"
  },
  "homepage": "https://github.com/beany-vu/michi-vz-mono#readme",
  "bugs": "https://github.com/beany-vu/michi-vz-mono/issues"
}
