{
  "name": "@michi-vz/angular",
  "version": "0.0.0",
  "description": "Angular wrapper for michi-vz charts",
  "type": "module",
  "files": ["dist"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "require": "./dist/index.cjs" }
  },
  "scripts": { "build": "tsup", "typecheck": "tsc --noEmit" },
  "publishConfig": { "access": "public" },
  "dependencies": { "@michi-vz/core": "workspace:*" },
  "peerDependencies": { "@angular/core": ">=16" }
}
