{
  "name": "@michi-vz/angular",
  "version": "1.1.0",
  "description": "Angular wrapper for michi-vz charts. The multi-framework fork of the original React-only michi-vz (github.com/beany-vu/michi-vz).",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@michi-vz/core": "workspace:*",
    "@michi-vz/wc": "workspace:*"
  },
  "peerDependencies": {
    "@angular/core": ">=16"
  },
  "license": "MIT",
  "author": "Beany Vu",
  "keywords": [
    "charts",
    "angular",
    "dataviz",
    "web-components"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beany-vu/michi-vz-mono.git",
    "directory": "packages/angular"
  },
  "homepage": "https://michi-vz.netlify.app/",
  "bugs": "https://github.com/beany-vu/michi-vz-mono/issues"
}
