{
  "name": "@michi-vz/core",
  "version": "0.0.0",
  "description": "Framework-agnostic chart rendering engine + LLM-ready ChartContext",
  "type": "module",
  "sideEffects": ["**/*.css"],
  "files": ["dist"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "require": "./dist/index.cjs" },
    "./styles.css": "./dist/styles/core.css"
  },
  "scripts": { "build": "tsup", "typecheck": "tsc --noEmit" },
  "publishConfig": { "access": "public" },
  "dependencies": {
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.2.3",
    "simple-statistics": "^7.8.8"
  },
  "devDependencies": {
    "@types/d3-array": "^3.2.1",
    "@types/d3-scale": "^4.0.8",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-shape": "^3.1.7"
  }
}
