{
  "name": "@michi-vz/core",
  "version": "1.1.1",
  "description": "Framework-agnostic chart rendering engine + LLM-ready ChartContext. The multi-framework fork of the original React-only michi-vz (github.com/beany-vu/michi-vz).",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles/core.css"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "dompurify": "^3.2.3"
  },
  "devDependencies": {
    "@types/d3-scale": "^4.0.8",
    "@types/d3-shape": "^3.1.7",
    "jsdom": "^25.0.1",
    "vitest": "^2.1.8"
  },
  "license": "MIT",
  "author": "Beany Vu",
  "keywords": [
    "charts",
    "chart",
    "dataviz",
    "data-visualization",
    "svg",
    "canvas",
    "d3",
    "framework-agnostic",
    "web-components",
    "llm",
    "accessibility"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beany-vu/michi-vz-mono.git",
    "directory": "packages/core"
  },
  "homepage": "https://michi-vz.netlify.app/",
  "bugs": "https://github.com/beany-vu/michi-vz-mono/issues"
}
